# Copy this file to .env for local development.
# Do not commit real secrets.

# AI provider settings for future report and image generation features.
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_IMAGE_MODEL=

# Telegram notification settings for future lead handoff.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Local demo database path.
DATABASE_URL=sqlite:./backend/database/demo_database.sqlite

# Local app settings.
APP_ENV=development
APP_BASE_URL=http://localhost:3000
